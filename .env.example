# Copy this file to .env and fill in your site-specific values.
# .env is gitignored — it holds your LAN IPs, callsign, and coordinates.

# Ecowitt GW3000 local poll endpoint
GW3000_URL=http://192.168.1.115/get_livedata_info
POLL_INTERVAL_SEC=60

# Any server speaking the standard APRS-IS TCP login protocol:
#   - a WX3in1 Plus 2.0 "simple server" (for RF gating) — use the
#     literal user/pass configured on its APRS-IS simple server tab
#   - a real APRS-IS server, e.g. noam.aprs2.net:14580 — use your
#     callsign and real APRS-IS passcode to inject straight to the network
APRS_SERVER_HOST=192.168.1.100
APRS_SERVER_PORT=14580
APRS_LOGIN_USER=your-callsign
APRS_LOGIN_PASS=-1

# APRS identity/position for the transmitted weather packet
APRS_CALL=YOURCALL-13
APRS_LAT=3337.57N
APRS_LON=08639.76W
APRS_COMMENT=

# Minutes between beacons
RF_INTERVAL_MIN=10
